NODE_ENV=development
PORT=3000

HAKAI_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HAKAI_JSON_BODY_LIMIT=32kb

HAKAI_CHAT_LOGS_ENABLED=true
HAKAI_VERBOSE_CHAT_LOGS=false
HAKAI_OPENAI_PLANNER_ENABLED=true
# Non-production regression helper. Ignored when NODE_ENV=production.
HAKAI_DISABLE_RATE_LIMITS=false

HAKAI_RATE_LIMIT_MAX=30
HAKAI_RATE_LIMIT_WINDOW_MS=60000

HAKAI_AUTH_RATE_LIMIT_MAX=10
HAKAI_AUTH_RATE_LIMIT_WINDOW_MS=60000
HAKAI_AUTH_TOKEN_TTL_SECONDS=604800
HAKAI_PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
HAKAI_PUBLIC_APP_URL=http://localhost:3000
# Optional local dev override. By default auth writes server/.data/users.json.
# HAKAI_USER_STORE_PATH=.data/users.json
# Optional local dev password reset outbox. Stores dev-only reset URLs; do not use in production.
# HAKAI_PASSWORD_RESET_DEV_OUTBOX_PATH=.data/password-reset-dev-outbox.json

# Optional future email provider variables. Configure these in production before enabling
# password reset email delivery; never commit real credentials.
# HAKAI_EMAIL_PROVIDER=
# HAKAI_EMAIL_API_KEY=
# HAKAI_EMAIL_FROM=

# Required for auth outside isolated tests. Set a long random value in server/.env
# or the hosting environment. Do not commit real secrets.
# HAKAI_AUTH_JWT_SECRET=

# Put real provider/API keys only in server/.env or hosting environment variables.
# Never commit real secrets.
# OPENAI_API_KEY=
