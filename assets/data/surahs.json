[
  {
    "id": 103,
    "number": 103,
    "nameTr": "Asr",
    "nameAr": "العصر",
    "ayahs": [
      {
        "number": 1,
        "textAr": "وَالْعَصْرِ",
        "textTr": "Asra yemin olsun."
      },
      {
        "number": 2,
        "textAr": "إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ",
        "textTr": "İnsan gerçekten ziyan içindedir."
      },
      {
        "number": 3,
        "textAr": "إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ وَتَوَاصَوْا بِالْحَقِّ وَتَوَاصَوْا بِالصَّبْرِ",
        "textTr": "Ancak iman edip salih amel işleyen, hakkı ve sabrı tavsiye edenler başka."
      }
    ]
  },
  {
    "id": 108,
    "number": 108,
    "nameTr": "Kevser",
    "nameAr": "الكوثر",
    "ayahs": [
      {
        "number": 1,
        "textAr": "إِنَّا أَعْطَيْنَاكَ الْكَوْثَرَ",
        "textTr": "Şüphesiz biz sana Kevser'i verdik."
      },
      {
        "number": 2,
        "textAr": "فَصَلِّ لِرَبِّكَ وَانْحَرْ",
        "textTr": "Öyleyse Rabbin için namaz kıl ve kurban kes."
      },
      {
        "number": 3,
        "textAr": "إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ",
        "textTr": "Asıl soyu kesik olan sana kin duyandır."
      }
    ]
  },
  {
    "id": 109,
    "number": 109,
    "nameTr": "Kâfirûn",
    "nameAr": "الكافرون",
    "ayahs": [
      {
        "number": 1,
        "textAr": "قُلْ يَا أَيُّهَا الْكَافِرُونَ",
        "textTr": "De ki: Ey inkârcılar!"
      },
      {
        "number": 2,
        "textAr": "لَا أَعْبُدُ مَا تَعْبُدُونَ",
        "textTr": "Ben sizin taptıklarınıza tapmam."
      },
      {
        "number": 3,
        "textAr": "وَلَا أَنْتُمْ عَابِدُونَ مَا أَعْبُدُ",
        "textTr": "Siz de benim kulluk ettiğime kulluk etmezsiniz."
      },
      {
        "number": 4,
        "textAr": "وَلَا أَنَا عَابِدٌ مَا عَبَدْتُمْ",
        "textTr": "Ben sizin kulluk ettiklerinize kulluk edecek değilim."
      },
      {
        "number": 5,
        "textAr": "وَلَا أَنْتُمْ عَابِدُونَ مَا أَعْبُدُ",
        "textTr": "Siz de benim kulluk ettiğime kulluk edecek değilsiniz."
      },
      {
        "number": 6,
        "textAr": "لَكُمْ دِينُكُمْ وَلِيَ دِينِ",
        "textTr": "Sizin dininiz size, benim dinim banadır."
      }
    ]
  },
  {
    "id": 112,
    "number": 112,
    "nameTr": "İhlâs",
    "nameAr": "الإخلاص",
    "ayahs": [
      {
        "number": 1,
        "textAr": "قُلْ هُوَ اللَّهُ أَحَدٌ",
        "textTr": "De ki: O Allah birdir."
      },
      {
        "number": 2,
        "textAr": "اللَّهُ الصَّمَدُ",
        "textTr": "Allah Samed'dir; her şey O'na muhtaçtır."
      },
      {
        "number": 3,
        "textAr": "لَمْ يَلِدْ وَلَمْ يُولَدْ",
        "textTr": "O doğurmamış ve doğmamıştır."
      },
      {
        "number": 4,
        "textAr": "وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ",
        "textTr": "Hiçbir şey O'na denk değildir."
      }
    ]
  },
  {
    "id": 113,
    "number": 113,
    "nameTr": "Felak",
    "nameAr": "الفلق",
    "ayahs": [
      {
        "number": 1,
        "textAr": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ",
        "textTr": "De ki: Sabahın Rabbine sığınırım."
      },
      {
        "number": 2,
        "textAr": "مِنْ شَرِّ مَا خَلَقَ",
        "textTr": "Yarattığı şeylerin şerrinden."
      },
      {
        "number": 3,
        "textAr": "وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ",
        "textTr": "Karanlığı çöktüğü zaman gecenin şerrinden."
      },
      {
        "number": 4,
        "textAr": "وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ",
        "textTr": "Düğümlere üfleyenlerin şerrinden."
      },
      {
        "number": 5,
        "textAr": "وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ",
        "textTr": "Haset ettiği zaman hasetçinin şerrinden."
      }
    ]
  },
  {
    "id": 114,
    "number": 114,
    "nameTr": "Nâs",
    "nameAr": "الناس",
    "ayahs": [
      {
        "number": 1,
        "textAr": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ",
        "textTr": "De ki: İnsanların Rabbine sığınırım."
      },
      {
        "number": 2,
        "textAr": "مَلِكِ النَّاسِ",
        "textTr": "İnsanların hükümdarına."
      },
      {
        "number": 3,
        "textAr": "إِلَهِ النَّاسِ",
        "textTr": "İnsanların ilahına."
      },
      {
        "number": 4,
        "textAr": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
        "textTr": "Sinsi vesvesecinin şerrinden."
      },
      {
        "number": 5,
        "textAr": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
        "textTr": "O ki insanların göğüslerine vesvese verir."
      },
      {
        "number": 6,
        "textAr": "مِنَ الْجِنَّةِ وَالنَّاسِ",
        "textTr": "Cinlerden ve insanlardan olan vesvesecilerin şerrinden."
      }
    ]
  }
]
